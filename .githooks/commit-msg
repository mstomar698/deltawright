#!/bin/sh
# Deltawright commit-msg: enforce Conventional Commits on the subject line.
# Allows merge / revert / fixup / squash commits through untouched.
header=$(head -n1 "$1")

case "$header" in
  "Merge "* | "Revert "* | "fixup! "* | "squash! "*) exit 0 ;;
esac

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?!?: .+'
if ! printf '%s' "$header" | grep -Eq "$pattern"; then
  echo "[commit-msg] ✗ Not a Conventional Commit:"
  echo "    $header"
  echo "  Expected: <type>[optional scope]: <subject>"
  echo "  Types: feat fix docs style refactor perf test build ci chore revert"
  exit 1
fi
