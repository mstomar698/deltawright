{
  "name": "deltawright",
  "version": "1.0.0",
  "description": "A delta-and-actionability layer for Playwright agents: it tells the agent what changed after an action and whether it can act on it.",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "playwright",
    "agent",
    "llm",
    "mcp",
    "browser-testing",
    "mutationobserver",
    "actionability",
    "delta"
  ],
  "homepage": "https://github.com/mstomar698/deltawright#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mstomar698/deltawright.git"
  },
  "bugs": {
    "url": "https://github.com/mstomar698/deltawright/issues"
  },
  "author": "mstomar698",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./mcp": {
      "types": "./dist/mcp/server.d.ts",
      "import": "./dist/mcp/server.js"
    },
    "./matchers": {
      "import": {
        "types": "./dist/matchers/index.d.ts",
        "default": "./dist/matchers/index.js"
      },
      "require": {
        "types": "./dist/matchers/index.d.cts",
        "default": "./dist/matchers/index.cjs"
      }
    },
    "./reporter": {
      "import": {
        "types": "./dist/reporter/index.d.ts",
        "default": "./dist/reporter/index.js"
      },
      "require": {
        "types": "./dist/reporter/index.d.cts",
        "default": "./dist/reporter/index.cjs"
      }
    },
    "./wait": {
      "import": {
        "types": "./dist/wait/index.d.ts",
        "default": "./dist/wait/index.js"
      },
      "require": {
        "types": "./dist/wait/index.d.cts",
        "default": "./dist/wait/index.cjs"
      }
    },
    "./aggregate": {
      "import": {
        "types": "./dist/aggregate/index.d.ts",
        "default": "./dist/aggregate/index.js"
      },
      "require": {
        "types": "./dist/aggregate/index.d.cts",
        "default": "./dist/aggregate/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "deltawright": "./dist/cli.js",
    "deltawright-mcp": "./dist/mcp/server.js"
  },
  "scripts": {
    "build": "node scripts/build.mjs",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "playwright test",
    "demo": "tsx demo/run-demo.ts",
    "demo:gwt": "tsx demo/run-gwt-demo.ts",
    "mcp": "tsx src/mcp/server.ts",
    "bench": "tsx bench/run-bench.ts",
    "bench:admissible": "tsx bench/run-admissible.ts",
    "bench:accuracy": "tsx bench/run-accuracy.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm test",
    "prepack": "npm run build",
    "prepare": "git config core.hooksPath .githooks || true"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^26.1.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0"
  },
  "peerDependencies": {
    "@playwright/test": ">=1.49.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "gpt-tokenizer": "^3.4.0",
    "pngjs": "^7.0.0",
    "zod": "^4.4.3"
  }
}
